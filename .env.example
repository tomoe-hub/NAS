# 認証（ログイン画面で使用）
# 本番・Vercel では Vercel の「Environment Variables」で設定してください。
AUTH_EMAIL=
AUTH_PASSWORD=
AUTH_SECRET=

# AUTH_SECRET は Cookie 署名用に 16 文字以上のランダム文字列を設定してください。
# 例: openssl rand -base64 24

# 追加ログイン（最大10件まで AUTH_EMAIL / AUTH_EMAIL_2 … _10）
# AUTH_EMAIL_2=
# パスワードは次のどちらか一方だけを設定（両方ある場合は B64 が優先される）
# - 平文: AUTH_PASSWORD_2=記号入りパスワードも可
# - Base64: AUTH_PASSWORD_B64_2=　← 中身は「パスワード文字列」を UTF-8 で Base64 エンコードした値。
#   平文パスワードをそのまま B64 変数名に入れないこと（デコード結果が別文字列になりログイン失敗する）
#   生成例（PowerShell）: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes('your-password'))
#   生成例（mac/Linux）: printf %s 'your-password' | base64

# S3（バケット名は S3_BUCKET_NAME など既存の変数で指定）
# 一次執筆が参照する資料フォルダ（キー先頭）。.md / .csv / .txt のみ読み込み。
# S3_DRAFT_MATERIALS_PREFIX=materials_for_articles/

# ─────────────────────────────────────────────
# Gemini / Claude (Bedrock) フォールバック設定
# ─────────────────────────────────────────────
# Google Gemini の API キー（必須）
# GEMINI_API_KEY=
#
# 使用する Gemini モデル候補（カンマ区切り・省略可）。
# 未設定時は gemini-2.5-flash → 2.5-flash-lite → 2.0-flash → 2.0-flash-lite の順に試行。
# ※ gemini-1.5-* は 2025年9月に廃止済み。指定しないこと。
# GEMINI_MODEL_LIST=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
#
# Gemini が 404/429/503 等で全滅した場合、AWS Bedrock 経由の Claude Sonnet 4.5 に自動フォールバックします。
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY が設定されていれば自動で有効化されます。
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Bedrock のリージョン（省略時 us-west-2）。Sonnet 4.5 を使うなら us-west-2 / us-east-1 推奨。
# BEDROCK_REGION=us-west-2
# CLAUDE_BEDROCK_REGION=us-west-2
#
# Claude のモデル上書き（通常不要・既定で Sonnet 4.5 → 3.5 Sonnet の順に試行）
# CLAUDE_BEDROCK_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0
# CLAUDE_BEDROCK_MODEL_FALLBACK=anthropic.claude-3-5-sonnet-20241022-v2:0
#
# Claude フォールバックを完全に無効化したい場合のみ "false" に設定
# CLAUDE_ENABLE_FALLBACK=true

# ─────────────────────────────────────────────
# ホワイトペーパーDLユーザー管理（DynamoDB）
# ─────────────────────────────────────────────
# 省略時は nts-whitepaper-leads を使用
# DYNAMODB_WHITEPAPER_LEADS_TABLE=nts-whitepaper-leads
#
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# 必要IAM権限: 対象テーブルへの dynamodb:Scan / dynamodb:DescribeTable / dynamodb:DeleteItem
# DeleteItem はホワイトペーパーパイプラインで明示的に完全削除する場合のみ使用
